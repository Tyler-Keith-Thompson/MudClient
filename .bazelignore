# SwiftPM build/checkout dirs — these contain stray BUILD/.bzl files that
# Bazel's //... target pattern must not recurse into.
.build
swift/.build
Scripts/AlterAeon/.build

# Python venvs (torch/torchgen etc. ship stray BUILD/.bzl files Bazel must not recurse into).
tools/tts/.venv
tools/finetune/.venv

# Agent worktrees are throwaway checkouts (their own BUILD/.bzl copies drift from main); Bazel's
# //... pattern must not recurse into them.
.claude/worktrees

# Convenience symlinks
bazel-bin
bazel-out
bazel-testlogs
bazel-MudClient
